DB_PASSWORD=changeme_in_production
SECRET_KEY=changeme_in_production
WEATHER_LAT=41.2
WEATHER_LON=-87.2
FUEL_API_KEY=changeme_in_production
NASA_API_KEY=DEMO_KEY
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# APNs (Apple Push Notifications) — leave blank to disable push notifications
# Generate a key at: https://developer.apple.com/account/resources/authkeys
APNS_KEY_FILE=/app/certs/apns-key.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.chaseburrell.Datacore
APNS_USE_SANDBOX=true

# Trak-4 GPS Tracking API
# Find your API key in User Settings at https://gps.trak-4.com
TRAK4_API_KEY=
# Webhook secret — set this to match the x-api-key value in your Trak-4 org/user settings
# Trak-4 will send this as an HTTP header to authenticate webhook deliveries
TRAK4_WEBHOOK_SECRET=
